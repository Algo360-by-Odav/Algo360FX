# Application Configuration
# ---------------------
NODE_ENV=development                 # Options: development, production, test
PORT=3000                           # Application port
API_VERSION=v1                      # API version
DEBUG=false                         # Enable debug mode
LOG_LEVEL=info                      # Options: error, warn, info, debug

# Database Configuration
# ---------------------
DATABASE_URL=                       # Format: postgresql://user:pass@host:5432/dbname
DATABASE_SSL=false                  # Enable SSL for database connection

# Redis Configuration
# ------------------
REDIS_URL=                         # Format: redis://host:port/db
REDIS_PASSWORD=                    # Redis password if required

# Authentication
# -------------
JWT_SECRET=                        # Secret key for JWT tokens
JWT_REFRESH_SECRET=                # Secret for refresh tokens
JWT_ACCESS_EXPIRATION=15m          # Access token expiration
JWT_REFRESH_EXPIRATION=7d          # Refresh token expiration

# WebSocket Configuration
# ----------------------
WS_PORT=8081                       # WebSocket port
WS_PATH=/ws                        # WebSocket endpoint path
WS_HEARTBEAT_INTERVAL=30000        # Heartbeat interval in ms

# Trading Parameters
# -----------------
TRADING_ENABLED=true               # Enable/disable trading
DEFAULT_LEVERAGE=100               # Default leverage for new positions
MAX_LEVERAGE=500                   # Maximum allowed leverage
MIN_VOLUME=0.01                    # Minimum trade volume
MAX_VOLUME=100                     # Maximum trade volume
MAX_SLIPPAGE=3                     # Maximum allowed slippage in pips
DEFAULT_STOP_LOSS=50              # Default stop loss in pips
DEFAULT_TAKE_PROFIT=100           # Default take profit in pips
RISK_PERCENTAGE=1                  # Risk per trade as percentage
MAX_TRADES_PER_SYMBOL=5           # Maximum trades per symbol
MAX_DAILY_TRADES=20               # Maximum daily trades
TRADING_HOURS=00:00-23:59         # Trading hours
TRADING_DAYS=1,2,3,4,5            # Trading days (1=Monday)

# Market Data
# ----------
MARKET_DATA_PROVIDER=MT5           # Market data provider
MARKET_API_KEY=                    # Market data API key
MARKET_API_URL=                    # Market data API URL
MARKET_UPDATE_INTERVAL=1000        # Price update interval in ms
SUPPORTED_SYMBOLS=EURUSD,GBPUSD    # Supported trading symbols
DEFAULT_TIMEFRAMES=M1,M5,M15,H1    # Default timeframes

# AI/ML Configuration
# ------------------
OPENAI_API_KEY=                    # OpenAI API key
AI_MODEL=gpt-4                     # AI model to use
AI_MAX_TOKENS=2000                 # Maximum tokens per request
AI_TEMPERATURE=0.7                 # AI response temperature
SENTIMENT_ANALYSIS_ENABLED=true    # Enable sentiment analysis
RISK_ASSESSMENT_ENABLED=true       # Enable risk assessment

# News Integration
# ---------------
NEWS_API_KEY=                      # News API key
NEWS_UPDATE_INTERVAL=300000        # News update interval in ms
NEWS_SOURCES=reuters,bloomberg     # News sources

# Security Settings
# ----------------
CORS_ORIGIN=http://localhost:3001  # CORS origin URL
RATE_LIMIT_WINDOW=900000          # Rate limit window in ms
RATE_LIMIT_MAX=1000               # Maximum requests per window
BCRYPT_ROUNDS=10                  # BCrypt password hashing rounds
SESSION_SECRET=                    # Session secret key
ALLOWED_HOSTS=localhost           # Allowed hostnames

# Monitoring
# ----------
SENTRY_DSN=                       # Sentry DSN for error tracking
METRICS_ENABLED=true              # Enable metrics collection
TRACE_ENABLED=true               # Enable request tracing
HEALTH_CHECK_INTERVAL=30000      # Health check interval in ms

# Cache Settings
# -------------
CACHE_TTL=3600                   # Cache TTL in seconds
CACHE_MAX_SIZE=1000              # Maximum cache entries
CACHE_CHECK_PERIOD=600           # Cache cleanup interval

# Email Configuration
# ------------------
SMTP_HOST=                       # SMTP server host
SMTP_PORT=587                    # SMTP server port
SMTP_USER=                       # SMTP username
SMTP_PASS=                       # SMTP password
EMAIL_FROM=noreply@algo360fx.com # From email address

# Feature Flags
# ------------
FEATURE_SOCIAL_TRADING=true      # Enable social trading
FEATURE_COPY_TRADING=true       # Enable copy trading
FEATURE_PAPER_TRADING=true      # Enable paper trading
FEATURE_BACKTESTING=true        # Enable strategy backtesting
FEATURE_PORTFOLIO_ANALYSIS=true # Enable portfolio analysis
FEATURE_RISK_MANAGEMENT=true    # Enable risk management
FEATURE_AUTOMATED_TRADING=true  # Enable automated trading

# Development Tools
# ----------------
SWAGGER_ENABLED=true            # Enable Swagger documentation
PLAYGROUND_ENABLED=true         # Enable GraphQL playground
SEED_DATABASE=false            # Enable database seeding

# Client URLs
# ----------
VITE_API_URL=https://algo360fx-frontend.onrender.com  # API URL for client
VITE_WS_URL=wss://algo360fx-frontend.onrender.com    # WebSocket URL for client
