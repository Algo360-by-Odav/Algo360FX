# API Configuration
VITE_API_URL=https://algo360fx-server.onrender.com
VITE_WS_URL=wss://algo360fx-server.onrender.com/ws
VITE_API_TIMEOUT=30000
VITE_API_RETRY_ATTEMPTS=3

# Server Configuration
PORT=3000
VITE_SERVER_REGION=us-east-1
VITE_SERVER_ENVIRONMENT=production

# Feature Flags
VITE_ENABLE_MOCK_DATA=false
VITE_ENABLE_DEBUG_TOOLS=false
VITE_ENABLE_DEMO_ACCOUNT=true
VITE_ENABLE_SOCIAL_LOGIN=true

# Trading Configuration
VITE_MAX_CHART_CANDLES=1000
VITE_CHART_UPDATE_INTERVAL=1000
VITE_ORDER_BOOK_DEPTH=10
VITE_MAX_LEVERAGE=100
VITE_MIN_TRADE_AMOUNT=0.01
VITE_MAX_TRADE_AMOUNT=100
VITE_PRICE_PRECISION=5
VITE_AMOUNT_PRECISION=2
VITE_ENABLE_MARGIN_TRADING=true
VITE_ENABLE_FUTURES_TRADING=true
VITE_ENABLE_COPY_TRADING=true

# Authentication
VITE_JWT_EXPIRY=3600
VITE_REFRESH_TOKEN_EXPIRY=604800
VITE_MAX_LOGIN_ATTEMPTS=5
VITE_ENABLE_2FA=true
VITE_ENABLE_BIOMETRIC=true

# Analytics
VITE_ENABLE_ANALYTICS=true
VITE_GA_TRACKING_ID=G-XXXXXXXXXX
VITE_MIXPANEL_TOKEN=XXXXXXXXXX
VITE_SENTRY_DSN=https://XXXXXXXXXX@XXXXXXXXXX.ingest.sentry.io/XXXXXXXXXX

# PWA
VITE_ENABLE_PWA=true
VITE_APP_VERSION=1.0.0
VITE_APP_BUILD=production

# Security
VITE_ENABLE_CSP=true
VITE_ENABLE_HSTS=true
VITE_ENABLE_RATE_LIMIT=true
VITE_ENABLE_IP_FILTERING=true

# Performance
VITE_ENABLE_COMPRESSION=true
VITE_ENABLE_PRELOAD=true
VITE_ENABLE_PREFETCH=true
VITE_ENABLE_LAZY_LOADING=true
VITE_CACHE_TTL=3600
