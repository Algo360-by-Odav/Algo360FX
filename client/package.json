    "@mui/material": "^5.14.20",
    "@reduxjs/toolkit": "^2.0.1",
    "aws-amplify": "^6.0.7",
    "axios": "^1.6.2",
    "chart.js": "^4.4.1",
    "d3": "^7.8.5",
    "lightweight-charts": "^4.1.1",
    "lodash": "^4.17.21",
    "milliparsec": "^4.0.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^9.0.4",
