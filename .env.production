# Environment
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# API Configuration
VITE_API_URL=https://algo360fx-api.onrender.com
VITE_API_PORT=443
VITE_APP_NAME=Algo360FX
VITE_APP_DESCRIPTION=Advanced Algorithmic Trading Platform
VITE_APP_VERSION=1.0.0
VITE_SUPPORT_EMAIL=support@algo360fx.com
VITE_CONTACT_EMAIL=contact@algo360fx.com
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_SENTRY=true

# WebSocket Configuration
VITE_WS_URL=wss://algo360fx-api.onrender.com
VITE_WS_PATH=/ws

# Redis Configuration
REDIS_URL=${REDIS_URL}

# Database Configuration
DATABASE_URL=${DATABASE_URL}

# JWT Configuration
JWT_SECRET=${JWT_SECRET}

# CORS Configuration
CORS_ORIGIN=https://algo360fx-api.onrender.com

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Cache Configuration
CACHE_TTL=3600

# SSL Configuration
SSL_ENABLED=true
SSL_CERT=${SSL_CERT}
SSL_KEY=${SSL_KEY}
SSL_CA=${SSL_CA}

# Security Headers
SECURITY_HEADERS_ENABLED=true
HSTS_MAX_AGE=31536000
CSP_ENABLED=true
