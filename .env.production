# Environment
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# API Configuration
VITE_API_URL=https://algo360fx-api.onrender.com
VITE_API_PORT=443
VITE_APP_NAME=Algo360FX
VITE_APP_DESCRIPTION=Advanced Algorithmic Trading Platform
VITE_APP_VERSION=1.0.0
VITE_SUPPORT_EMAIL=support@algo360fx.com
VITE_CONTACT_EMAIL=contact@algo360fx.com
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_SENTRY=true

# Application Configuration
NODE_ENV=production
PORT=3000
API_VERSION=v1
DEBUG=false
LOG_LEVEL=info

# Database Configuration
DATABASE_URL=${DATABASE_URL}
DATABASE_SSL=true

# Redis Configuration
REDIS_URL=${REDIS_URL}
REDIS_PASSWORD=${REDIS_PASSWORD}

# Authentication
JWT_SECRET=${JWT_SECRET}
JWT_REFRESH_SECRET=${JWT_REFRESH_SECRET}
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# WebSocket Configuration
VITE_WS_URL=wss://algo360fx-api.onrender.com
VITE_WS_PATH=/ws
WS_PORT=8081
WS_PATH=/ws
WS_HEARTBEAT_INTERVAL=30000

# Trading Parameters
TRADING_ENABLED=true
DEFAULT_LEVERAGE=100
MAX_LEVERAGE=500
MIN_VOLUME=0.01
MAX_VOLUME=100
MAX_SLIPPAGE=3
DEFAULT_STOP_LOSS=50
DEFAULT_TAKE_PROFIT=100
RISK_PERCENTAGE=1
MAX_TRADES_PER_SYMBOL=5
MAX_DAILY_TRADES=20
TRADING_HOURS=00:00-23:59
TRADING_DAYS=1,2,3,4,5

# Market Data
MARKET_DATA_PROVIDER=MT5
MARKET_API_KEY=${MARKET_API_KEY}
MARKET_API_URL=https://api.market.com
MARKET_UPDATE_INTERVAL=1000
SUPPORTED_SYMBOLS=EURUSD,GBPUSD,USDJPY,AUDUSD,USDCAD,USDCHF,NZDUSD
DEFAULT_TIMEFRAMES=M1,M5,M15,M30,H1,H4,D1

# AI/ML Configuration
OPENAI_API_KEY=${OPENAI_API_KEY}
AI_MODEL=gpt-4
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.7
SENTIMENT_ANALYSIS_ENABLED=true
RISK_ASSESSMENT_ENABLED=true

# News Integration
NEWS_API_KEY=${NEWS_API_KEY}
NEWS_UPDATE_INTERVAL=300000
NEWS_SOURCES=reuters,bloomberg,forexlive

# Security Settings
CORS_ORIGIN=https://algo360fx-client.onrender.com
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=1000
BCRYPT_ROUNDS=12
SESSION_SECRET=${SESSION_SECRET}
ALLOWED_HOSTS=algo360fx-client.onrender.com,algo360fx-api.onrender.com

# Monitoring
SENTRY_DSN=${SENTRY_DSN}
METRICS_ENABLED=true
TRACE_ENABLED=true
HEALTH_CHECK_INTERVAL=30000

# Cache Settings
CACHE_TTL=3600
CACHE_MAX_SIZE=10000
CACHE_CHECK_PERIOD=600

# Email Configuration
SMTP_HOST=${SMTP_HOST}
SMTP_PORT=${SMTP_PORT}
SMTP_USER=${SMTP_USER}
SMTP_PASS=${SMTP_PASS}
EMAIL_FROM=noreply@algo360fx.com

# Feature Flags
FEATURE_SOCIAL_TRADING=true
FEATURE_COPY_TRADING=true
FEATURE_PAPER_TRADING=true
FEATURE_BACKTESTING=true
FEATURE_PORTFOLIO_ANALYSIS=true
FEATURE_RISK_MANAGEMENT=true
FEATURE_AUTOMATED_TRADING=true

# Development Tools
SWAGGER_ENABLED=false
PLAYGROUND_ENABLED=false
SEED_DATABASE=false

# Client URLs
VITE_API_URL=https://algo360fx-api.onrender.com
VITE_WS_URL=wss://algo360fx-api.onrender.com
