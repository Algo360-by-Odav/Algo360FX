# Server Configuration
NODE_ENV=development
PORT=3001
HOST=localhost

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/algo360fx?schema=public
DATABASE_SSL=false
DATABASE_MAX_CONNECTIONS=10
DATABASE_IDLE_TIMEOUT=10000

# JWT Authentication
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ALGORITHM=HS256

# MT5 Configuration
MT5_WS_PORT=6780
MT5_ACCOUNT_ID=your_mt5_account_id
META_API_TOKEN=your_meta_api_token_here
META_API_URL=https://mt-manager-api.metaapi.cloud/v1

# Market Data API
MARKET_API_KEY=your_finnhub_api_key_here
MARKET_API_URL=https://finnhub.io/api/v1
MARKET_API_TIMEOUT=5000
MARKET_DATA_CACHE_TTL=300

# WebSocket Settings
WS_PORT=3002
WS_HEARTBEAT_INTERVAL=30000
WS_RECONNECT_DELAY=5000
WS_MAX_CONNECTIONS=1000

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7
OPENAI_TIMEOUT=30000

# AI Model Settings
AI_CONFIDENCE_THRESHOLD=0.7
AI_UPDATE_INTERVAL=300000
AI_MAX_RETRIES=3
AI_BATCH_SIZE=50

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_MESSAGE="Too many requests from this IP, please try again later"
RATE_LIMIT_STORE=redis

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0
REDIS_PREFIX=algo360fx:

# CORS Configuration
ALLOWED_ORIGINS=["http://localhost:3000"]
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=Content-Type,Authorization,X-Requested-With
CORS_CREDENTIALS=true

# Security
ENABLE_SECURITY_HEADERS=true
ENABLE_DETAILED_LOGGING=true
LOG_LEVEL=debug
BCRYPT_SALT_ROUNDS=12
SESSION_SECRET=your_session_secret_here
COOKIE_SECRET=your_cookie_secret_here

# Monitoring and Analytics
SENTRY_DSN=your_sentry_dsn_here
NEW_RELIC_LICENSE_KEY=your_new_relic_key_here
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_ERROR_TRACKING=true

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_app_specific_password_here
SMTP_FROM="Algo360FX <noreply@algo360fx.com>"

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_FREQUENCY=86400
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your_backup_bucket_name

# Feature Flags
ENABLE_REAL_TIME_UPDATES=true
ENABLE_AI_PREDICTIONS=true
ENABLE_SOCIAL_TRADING=false
ENABLE_DEMO_MODE=false
