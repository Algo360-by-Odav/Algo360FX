# Server Configuration
NODE_ENV=development
PORT=3001
HOST=localhost

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5433/algo360fx
DATABASE_SSL=false
DATABASE_MAX_CONNECTIONS=10
DATABASE_IDLE_TIMEOUT=10000

# Redis Configuration (optional in development)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=algo360fx:

# JWT Authentication
JWT_SECRET=dev_jwt_secret
JWT_REFRESH_SECRET=dev_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ALGORITHM=HS256

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=Content-Type,Authorization,X-Requested-With
CORS_CREDENTIALS=true

# Security
ENABLE_SECURITY_HEADERS=true
ENABLE_DETAILED_LOGGING=true
LOG_LEVEL=debug
BCRYPT_SALT_ROUNDS=12
SESSION_SECRET=dev_session_secret
COOKIE_SECRET=dev_cookie_secret

# Market Data APIs
MARKET_DATA_API=https://api.marketdata.com/v1
MARKET_API_KEY=your_market_api_key_here
NEWS_API_URL=https://api.newsdata.com/v1
NEWS_API_KEY=your_news_api_key_here

# OpenAI Integration
OPENAI_API_KEY=your_openai_api_key_here
