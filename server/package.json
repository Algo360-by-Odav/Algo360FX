{
  "name": "algo360fx-server",
  "version": "1.0.0",
  "description": "Server for Algo360FX",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "clean": "del /f /s /q dist > nul 2>&1 || true",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:prod": "cross-env NODE_ENV=production node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "npm run typeorm migration:generate",
    "migration:run": "npm run typeorm migration:run",
    "migration:revert": "npm run typeorm migration:revert"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "metaapi.cloud-sdk": "^23.1.1",
    "mongodb-memory-server": "^9.5.0",
    "mongoose": "^8.9.2",
    "openai": "^4.77.0",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.1",
    "technicalindicators": "^3.1.0",
    "typeorm": "^0.3.19",
    "underscore": "^1.13.6",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/socket.io": "^3.0.1",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "cross-env": "^7.0.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
