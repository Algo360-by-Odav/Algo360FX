{
  "name": "algo360fx-server",
  "version": "1.0.0",
  "description": "Algo360FX Trading Platform Server",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "rimraf dist types && tsc",
    "build:clean": "rimraf dist types .tsbuildinfo && tsc",
    "build:watch": "tsc --watch",
    "clean:build": "rimraf dist types .tsbuildinfo",
    "test": "jest --config jest.config.ts",
    "test:watch": "jest --config jest.config.ts --watch",
    "test:coverage": "jest --config jest.config.ts --coverage",
    "test:ci": "jest --config jest.config.ts --ci --coverage --reporters='default' --reporters='jest-junit'",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:reset": "prisma migrate reset --force",
    "seed": "ts-node prisma/seed.ts",
    "clean": "rimraf dist",
    "docker:build": "docker build -t algo360fx-server .",
    "docker:run": "docker run -p 3000:3000 algo360fx-server",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean:cache": "rimraf .cache mongodb-binaries *.lock",
    "clean:db": "rimraf data/db dump mongodb",
    "clean:metaapi": "rimraf .metaapi MetaApi-*.bin MetaApi-*.json metaapi.*.log",
    "clean:trading": "rimraf trading-data historical-data backtests",
    "clean:coverage": "rimraf coverage .coverage coverage.json .nyc_output",
    "clean:all": "npm run clean:cache && npm run clean:db && npm run clean:metaapi && npm run clean:trading && npm run clean:coverage",
    "generate:certs": "ts-node scripts/generate-certs.ts",
    "dev:secure": "SSL_ENABLED=true npm run dev"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "envalid": "^8.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "metaapi.cloud-sdk": "^23.1.1",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "node-forge": "^1.3.1",
    "openai": "^4.24.1",
    "redis-om": "^0.4.3",
    "sanitize-html": "^2.14.0",
    "technicalindicators": "^3.1.0",
    "uuid": "^9.0.1",
    "winston": "^3.17.0",
    "ws": "^8.15.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@jest/types": "^29.6.3",
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/joi": "^17.2.2",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/sanitize-html": "^2.13.0",
    "@types/socket.io": "^3.0.1",
    "@types/socket.io-client": "^1.4.36",
    "@types/supertest": "^6.0.1",
    "@types/uuid": "^9.0.7",
    "@types/winston": "^2.4.4",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "chalk": "^4.1.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^28.10.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.1",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "jest-junit": "^16.0.0",
    "jest-mock-extended": "^3.0.5",
    "jest-serializer-path": "^0.1.15",
    "jest-watch-typeahead": "^2.2.2",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "prisma": "^6.1.0",
    "rimraf": "^5.0.5",
    "socket.io": "^4.8.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "ts-node prisma/seed.ts"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/tests"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.{js,ts}",
      "!src/**/*.d.ts",
      "!src/types/**/*",
      "!src/migrations/**/*",
      "!src/**/index.ts",
      "!src/tests/**/*"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "clover",
      "json",
      "html"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "coverageDirectory": "coverage",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/",
      "/__fixtures__/"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  }
}
